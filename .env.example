# ============================================================
# STUDIO CÔVADO — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local no Git.
# ============================================================

# --- Vercel Postgres (preenchido automaticamente pelo painel da Vercel) ---
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
POSTGRES_USER="USER"
POSTGRES_HOST="HOST"
POSTGRES_PASSWORD="PASSWORD"
POSTGRES_DATABASE="DATABASE"

# --- Aplicação ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Número do WhatsApp com DDI+DDD (ex: 554999999999)
NEXT_PUBLIC_WHATSAPP_NUMBER="5549XXXXXXXXX"

# --- Storage de Imagens (escolha UMA opção) ---

# Opção 1: Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXX"

# Opção 2: Cloudinary (gratuito até 25GB)
# CLOUDINARY_CLOUD_NAME="seu_cloud_name"
# CLOUDINARY_API_KEY="sua_api_key"
# CLOUDINARY_API_SECRET="seu_api_secret"
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="seu_cloud_name"

# --- Email (Resend) ---
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXX"
EMAIL_FROM="contato@studiocovado.com.br"
EMAIL_TO="contato@studiocovado.com.br"
